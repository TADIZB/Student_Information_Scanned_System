# Cấu hình kết nối Postgres (pgAdmin4 ở local).
# Ví dụ: postgresql+psycopg2://postgres:matkhau@localhost:5432/QR
DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/tadizb

# Danh sách origin được phép gọi API, phân tách bằng dấu phẩy.
# Mặc định cho dev: http://localhost:3000,http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
